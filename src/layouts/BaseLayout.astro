---
import '../styles/global.css';
import { withBase } from '../lib/data.js';

const { title, description, jsonld } = Astro.props;
const nav = [
  { href: '/techniques', label: 'Techniques' },
  { href: '/evidence-map', label: 'Evidence Map' },
  { href: '/research-library', label: 'Research Library' },
  { href: '/methodology', label: 'Methodology' },
  { href: '/about', label: 'About' },
];
const current = Astro.url.pathname.replace(/\/$/, '');
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Kept noindex until a qualified reviewer signs off (BRIEF.md 13, 18). -->
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} — Meditation Science Registry</title>
    <meta name="description" content={description} />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Ccircle cx='16' cy='16' r='14' fill='none' stroke='%2333484d' stroke-width='2'/%3E%3Ccircle cx='16' cy='16' r='4' fill='%2333484d'/%3E%3C/svg%3E" />
    {jsonld && <script type="application/ld+json" set:html={JSON.stringify(jsonld)} />}
  </head>
  <body>
    <div class="staging">Staging preview — not indexed. Evidence claims await sign-off by a qualified medical/scientific reviewer.</div>
    <header class="site-header">
      <div class="wrap">
        <a class="brand" href={withBase('/')}>Meditation Science Registry<span>Evidence, practice by practice</span></a>
        <nav class="nav" aria-label="Primary">
          {nav.map((n) => (
            <a href={withBase(n.href)} aria-current={current === withBase(n.href).replace(/\/$/, '') ? 'page' : undefined}>{n.label}</a>
          ))}
        </nav>
      </div>
    </header>
    <main>
      <div class="wrap">
        <slot />
      </div>
    </main>
    <footer class="site-footer">
      <div class="wrap">
        <div>
          Independent, volunteer-built. Informational only — not medical advice.<br />
          <a href={withBase('/about')}>Who's behind this</a> · <a href={withBase('/methodology')}>Methodology</a> · <a href={withBase('/llms.txt')}>llms.txt</a>
        </div>
        <div>Evidence current to July 2026. Reviewed monthly.</div>
      </div>
    </footer>
  </body>
</html>
